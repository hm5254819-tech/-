##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
##############################################################################

APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")

DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

OS_NAME=$(uname -s | tr '[:upper:]' '[:lower:]')

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
else
    JAVACMD=java
    if ! command -v java >/dev/null 2>&1 ; then
        die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH."
    fi
fi

# Resolve links
PRG="$0"
while [ -h "$PRG" ] ; do
    ls=$(ls -ld "$PRG")
    link=$(expr "$ls" : '.*-> \(.*\)$')
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=$(dirname "$PRG")/"$link"
    fi
done

SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null

APP_HOME=$(pwd -P)
cd "$SAVED"

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine if wrapper jar is present; if not, download it
if [ ! -f "$CLASSPATH" ] ; then
    echo "Downloading Gradle wrapper..."
    GRADLE_VERSION=$(grep distributionUrl "$APP_HOME/gradle/wrapper/gradle-wrapper.properties" | sed 's/.*gradle-\(.*\)-.*/\1/')
    WARNER_URL="https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-bin.zip"
    WARNER_BASE=$(basename "$WARNER_URL")
    cd "$APP_HOME"
    if command -v curl >/dev/null 2>&1 ; then
        curl -sSLO "$WARNER_URL"
    elif command -v wget >/dev/null 2>&1 ; then
        wget -q "$WARNER_URL"
    else
        die "Neither curl nor wget is available to download the Gradle wrapper."
    fi
    unzip -q "$WARNER_BASE" -d "$APP_HOME/gradle-tmp"
    cp "$APP_HOME/gradle-tmp/gradle-$GRADLE_VERSION/lib/gradle-wrapper-"*.jar "$CLASSPATH"
    rm -rf "$APP_HOME/gradle-tmp" "$WARNER_BASE"
    cd "$SAVED"
fi

# Use the standard Gradle wrapper jar to execute
exec "$JAVACMD" \
    $DEFAULT_JVM_OPTS \
    $JAVA_OPTS \
    $GRADLE_OPTS \
    "-Dorg.gradle.appname=$APP_BASE_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
